{
  "name": "@rightcapital/phpdoc-parser",
  "version": "0.6.2",
  "description": "TypeScript version of PHPDoc parser with support for intersection types and generics",
  "keywords": [
    "PHP",
    "PHPDoc",
    "PHPDoc Parser",
    "Parser",
    "TypeScript",
    "PHPStan",
    "AST",
    "Lexer"
  ],
  "repository": "https://github.com/RightCapitalHQ/phpdoc-parser",
  "license": "MIT",
  "author": "RightCapital Ecosystem team <npm-publisher@rightcapital.com>",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run clean && tsc --project ./tsconfig.build.json",
    "change": "nx release plan",
    "check": "nx release plan:check",
    "clean": "tsc --build --clean ./tsconfig.build.json",
    "commit": "cz",
    "eslint": "eslint --report-unused-disable-directives 'src/**/*.ts*'",
    "eslint:fix": "eslint --report-unused-disable-directives --fix 'src/**/*.ts*'",
    "preinstall": "npx only-allow pnpm",
    "test": "vitest"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "dependencies": {
    "lodash": "4.17.23"
  },
  "devDependencies": {
    "@babel/core": "7.26.9",
    "@babel/preset-env": "7.26.9",
    "@babel/preset-typescript": "7.26.0",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@commitlint/cz-commitlint": "20.5.1",
    "@nx/js": "22.0.2",
    "@rightcapital/eslint-config": "67.0.0",
    "@rightcapital/prettier-config": "8.0.4",
    "@types/lodash": "4.17.16",
    "@types/node": "24.12.2",
    "commitizen": "4.3.1",
    "eslint": "10.2.1",
    "husky": "9.1.7",
    "inquirer": "13.4.2",
    "nx": "22.0.2",
    "prettier": "3.5.3",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "peerDependencies": {
    "typescript": ">=5.8.0"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=16.x",
    "pnpm": ">=8.x"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  }
}
